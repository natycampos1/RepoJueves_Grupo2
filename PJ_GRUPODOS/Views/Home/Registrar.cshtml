@model UsuarioModel
@{
    Layout = "_LayoutExterno";
}

<div class="row h-100">
    <div class="col-lg-6 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a asp-action="Index" asp-controller="Home"><img src="~/images/logo-pasteleria.png" alt="Logo"></a>
            </div>
            <h1 class="auth-title">Crear Cuenta</h1>

            <form asp-action="Registrar" asp-controller="Home" method="post">

                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="Identificacion" type="text" class="form-control form-control-xl" placeholder="Identificación">
                    <div class="form-control-icon">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <span asp-validation-for="Identificacion" class="text-danger"></span>
                </div>

                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="Nombre" type="text" class="form-control form-control-xl" placeholder="Nombre">
                    <div class="form-control-icon">
                        <i class="bi bi-person"></i>
                    </div>
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="CorreoElectronico" type="text" class="form-control form-control-xl" placeholder="Correo Electrónico">
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                    <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                </div>

                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="Contrasenna" type="password" class="form-control form-control-xl" placeholder="Contraseña">
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <span asp-validation-for="Contrasenna" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-1">Procesar</button>
            </form>

            <div class="text-center mt-5 text-lg fs-4">
                <p class='text-gray-600'>
                    ¿Ya tienes una cuenta? <a asp-action="Index" asp-controller="Home" class="font-bold"> Inicia Sesión
                </a>
            </p>
        </div>
    </div>
</div>
<div class="col-lg-6 d-none d-lg-block">
    <div id="auth-right">
    </div>
</div>
</div>